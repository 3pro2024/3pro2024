generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Shuwa {
  id             Int         @id @default(autoincrement())
  word           String
  level          ShuwaLevel //クイズのレベル
  class          String //検定の階級
  prefecture     Prefecture?
  modelSentences String //例文
  howToDo        String //やり方
  videoUrl       String
  createdBy      String
  createdAt      DateTime    @default(now())
  updatedBy      String?
  updatedAt      DateTime?   @updatedAt
  quiz           Quiz?       // 追加：Quizへの逆方向のリレーション
}

model Quiz {
  id      Int       @id @default(autoincrement()) //独自のIdを持つ
  shuwaId Int       @unique //外部キーとして使用する
  shuwa   Shuwa     @relation(fields: [shuwaId], references: [id]) //Shuwaへの参照
  question     String //問題文
  option1      String //選択肢1
  option2      String //選択肢2
  option3      String //選択肢3
  answerNum    Int //正解のインデックス番号
  quizVideoUrl String
  createdBy    String
  createdAt    DateTime  @default(now())
  updatedBy    String?
  updatedAt    DateTime? @updatedAt
}

enum ShuwaLevel {
  初級
  中級
  上級
}

enum Prefecture {
  北海道
  青森県
  岩手県
  宮城県
  秋田県
  山形県
  福島県
  茨城県
  栃木県
  群馬県
  埼玉県
  千葉県
  東京都
  神奈川県
  新潟県
  富山県
  石川県
  福井県
  山梨県
  長野県
  岐阜県
  静岡県
  愛知県
  三重県
  滋賀県
  京都府
  大阪府
  兵庫県
  奈良県
  和歌山県
  鳥取県
  島根県
  岡山県
  広島県
  山口県
  徳島県
  香川県
  愛媛県
  高知県
  福岡県
  佐賀県
  長崎県
  熊本県
  大分県
  宮崎県
  鹿児島県
  沖縄県
}
